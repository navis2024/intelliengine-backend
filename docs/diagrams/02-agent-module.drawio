        <!-- ReAct 循环标注 -->
        <mxCell id="react-loop" value="&lt;b&gt;ReAct循环:&lt;/b&gt; Thought → Action → Observation → Thought → ... → FinalAnswer" style="rounded=1;fillColor=#fce4ec;strokeColor=#c62828;strokeWidth=2;fontSize=12;fontStyle=1;" vertex="1" parent="1">
